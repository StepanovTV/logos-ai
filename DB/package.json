{
  "name": "logos-db-manager",
  "version": "1.0.0",
  "scripts": {
    "start": "docker-compose up -d",
    "stop": "docker-compose down",
    "logs": "docker-compose logs -f",
    "reset": "docker-compose down -v && rm -rf data pgadmin_data && docker-compose up -d",
    "pgadmin": "docker-compose up -d pgadmin && open http://127.0.0.1:5050"
  }
}
